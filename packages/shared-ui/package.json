{
    "name": "@master-platform/shared-ui",
    "version": "0.0.0",
    "private": true,
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "storybook": "storybook dev -p 6006",
        "build:storybook": "storybook build",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist storybook-static"
    },
    "peerDependencies": {
        "react": "^18.0.0",
        "react-dom": "^18.0.0"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "lucide-react": "^0.414.0",
        "tailwind-merge": "^2.4.0"
    },
    "devDependencies": {
        "@storybook/addon-essentials": "^8.2.0",
        "@storybook/addon-interactions": "^8.2.0",
        "@storybook/addon-links": "^8.2.0",
        "@storybook/blocks": "^8.2.0",
        "@storybook/react": "^8.2.0",
        "@storybook/react-vite": "^8.2.0",
        "@storybook/test": "^8.2.0",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "autoprefixer": "^10.4.19",
        "postcss": "^8.4.40",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "^8.2.0",
        "tailwindcss": "^3.4.7",
        "tsup": "^8.2.4",
        "vite": "^5.3.5"
    }
}
