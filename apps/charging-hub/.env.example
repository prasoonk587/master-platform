# Server
PORT=3002
NODE_ENV=development

# Database (shared PostgreSQL instance, tables prefixed with charging_)
DATABASE_URL=postgresql://postgres:password@localhost:5432/master-platform

# Auth Service
AUTH_SERVICE_URL=http://localhost:3001

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
