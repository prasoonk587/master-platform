# Server
PORT=3001
NODE_ENV=development

# Database (shared PostgreSQL instance, tables prefixed with auth_)
DATABASE_URL=postgresql://postgres:password@localhost:5432/master-platform

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-this-to-another-long-random-secret-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
